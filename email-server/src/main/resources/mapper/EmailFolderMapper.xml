<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.email.mapper.EmailFolderMapper">

    <resultMap id="BaseResultMap" type="com.email.entity.EmailFolder">
        <id column="id" property="id"/>
        <result column="member_id" property="memberId"/>
        <result column="file_name" property="fileName"/>
        <result column="path" property="path"/>
        <result column="type" property="type"/>
        <result column="is_delete" property="isDelete"/>
        <result column="rule" property="rule"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findByMemberId" resultMap="BaseResultMap">
        SELECT * FROM email_folder
        WHERE member_id = #{memberId}
          AND is_delete = #{isDelete}
        ORDER BY create_time ASC
    </select>

    <select id="findByMemberIdAndPath" resultMap="BaseResultMap">
        SELECT * FROM email_folder
        WHERE member_id = #{memberId}
          AND path = #{path}
          AND is_delete = 0
        LIMIT 1
    </select>

</mapper>
