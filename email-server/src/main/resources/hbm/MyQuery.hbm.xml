<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <!-- 从 OA MyQuery.hbm.xml 原样复制，实体类名保持一致 -->
    <query name="internalmail_hibernate_findAllSummary"><![CDATA[
    from InMailSummary
]]></query>

    <query name="internalmail_hibernate_findSummaryByState"><![CDATA[
    from InMailSummary where STATE=:state
]]></query>

    <query name="internalmail_hibernate_findAffairByMemberIdAndState"><![CDATA[
    from InMailAffair where MEMBER_ID=:memberId and STATE=:state
]]></query>

    <query name="internalmail_hibernate_findAffairByInMailId"><![CDATA[
    from InMailAffair where OBJECT_ID=:objectId and (STATE>0 or STATE<0) order by CREATE_DATE desc
]]></query>
</hibernate-mapping>
