<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.email.platform.entity.OrgTeamMember" lazy="false" table="org_team_member">
        <id name="id" type="long" column="id" length="20">
            <generator class="assigned" />
        </id>
        <property name="teamId" type="long" column="team_id" />
        <property name="memberId" type="long" column="member_id" />
    </class>
</hibernate-mapping>
