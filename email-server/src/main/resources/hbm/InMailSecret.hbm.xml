<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.email.entity.InMailSecret" lazy="false" table="pro_inmail_secret">
        <id name="id" type="long" column="ID" length="20">
            <generator class="assigned" />
        </id>
        <property name="memberId" type="long" column="MEMBER_ID" />
        <property name="loginName" type="string" column="LOGIN_NAME" />
        <property name="pwd" type="string" column="PWD" />
        <property name="state" type="integer" column="STATE" />
        <property name="createDate" column="CREATE_DATE" type="timestamp" />
        <property name="updateDate" column="UPDATE_DATE" type="timestamp" />
        <property name="ext1" type="string" column="EXT1" />
        <property name="ext2" type="string" column="EXT2" />
        <property name="ext3" type="string" column="EXT3" />
        <property name="ext4" type="string" column="EXT4" />
        <property name="ext5" type="string" column="EXT5" />
    </class>
</hibernate-mapping>
